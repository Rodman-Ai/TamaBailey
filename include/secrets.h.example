#pragma once

// Copy this file to include/secrets.h and fill in real credentials.
// include/secrets.h is gitignored.
//
// On boot, esp_clock.cpp reads these to join your Wi-Fi network and
// sync NTP time. Once synced, Bailey gets a real day/night cycle,
// daily-visit streaks, and offline decay catch-up.
//
// If you don't fill these in, the firmware still runs perfectly --
// it just uses a synthetic 24-minute day/night loop instead of real
// local time, and streak/offline-catchup features stay dormant.

#define WIFI_SSID "your-ssid-here"
#define WIFI_PASS "your-password-here"
